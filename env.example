# ============================================================
# Your Car Your Way — PoC Chat — Environment Variables
# ============================================================
# This file must NOT be committed to Git (listed in .gitignore).
# Copy .env.example to .env and adjust values as needed.
# ============================================================

# ── PostgreSQL ──
POSTGRES_DB=ycyw
POSTGRES_USER=ycyw
POSTGRES_PASSWORD=ycyw_secret

# ── Spring Boot ──
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws
